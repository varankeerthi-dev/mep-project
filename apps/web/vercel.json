{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "crons": [
    {
      "path": "/api/work-instruction-draft",
      "schedule": "30 0 * * *"
    }
  ],
  "rewrites": [
    {
      "source": "/_astro/:path*",
      "destination": "https://astro-wheat-eight.vercel.app/_astro/:path*"
    },
    {
      "source": "/favicon.:ext",
      "destination": "https://astro-wheat-eight.vercel.app/favicon.:ext"
    },
    {
      "source": "/pricing",
      "destination": "https://astro-wheat-eight.vercel.app/pricing"
    },
    {
      "source": "/help",
      "destination": "https://astro-wheat-eight.vercel.app/help"
    },
    {
      "source": "/help/:path*",
      "destination": "https://astro-wheat-eight.vercel.app/help/:path*"
    },
    {
      "source": "/industries/:path*",
      "destination": "https://astro-wheat-eight.vercel.app/industries/:path*"
    },
    {
      "source": "/sitemap-:n.xml",
      "destination": "https://astro-wheat-eight.vercel.app/sitemap-:n.xml"
    },
    {
      "source": "/sitemap-index.xml",
      "destination": "https://astro-wheat-eight.vercel.app/sitemap-index.xml"
    },
    {
      "source": "/",
      "destination": "https://astro-wheat-eight.vercel.app/"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ]
}
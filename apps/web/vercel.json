{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "crons": [
    {
      "path": "/api/work-instruction-draft",
      "schedule": "30 0 * * *"
    }
  ],
  "rewrites": [
    {
      "source": "/pricing",
      "destination": "/pricing/index.html"
    },
    {
      "source": "/help",
      "destination": "/help/index.html"
    },
    {
      "source": "/help/:path*",
      "destination": "/help/:path*/index.html"
    },
    {
      "source": "/industries/:path*",
      "destination": "/industries/:path*/index.html"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ]
}